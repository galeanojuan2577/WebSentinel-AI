# WebSentinel-AI Configuration

# Scanner
SCANNER_TIMEOUT=30
SCANNER_MAX_REDIRECTS=5
SCANNER_USER_AGENT=WebSentinel-AI/0.3
SCANNER_RATE_LIMIT=10

# Database
DATABASE_URL=sqlite+aiosqlite:///~/.websentinel/websentinel.db

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Reports
REPORT_OUTPUT_DIR=./reports
